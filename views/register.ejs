<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="/css/pages.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏠</text></svg>" />
</head>
<body>

<div class="auth-page" style="min-height:100vh;">
  <!-- Visual Side -->
  <aside class="auth-visual">
    <div class="auth-visual-img" aria-hidden="true"></div>
    <div class="auth-visual-content">
      <div class="auth-visual-logo">Nest<span>Dubai</span></div>
      <h2>Join 500+ International Students in Dubai</h2>
      <p>Create your free account and book your room in minutes. No deposit required to browse.</p>

      <div class="auth-feature">
        <div class="auth-feature-icon" aria-hidden="true">⚡</div>
        <div class="auth-feature-text">
          <h5>Book in 3 Minutes</h5>
          <p>Register, choose your room, and confirm your booking — all online.</p>
        </div>
      </div>
      <div class="auth-feature">
        <div class="auth-feature-icon" aria-hidden="true">🌍</div>
        <div class="auth-feature-text">
          <h5>International Students Welcome</h5>
          <p>We support students from every country with flexible move-in dates.</p>
        </div>
      </div>
      <div class="auth-feature">
        <div class="auth-feature-icon" aria-hidden="true">🛡️</div>
        <div class="auth-feature-text">
          <h5>Safe & Secure Platform</h5>
          <p>Your data is encrypted. Payments processed securely via Stripe.</p>
        </div>
      </div>
    </div>
  </aside>

  <!-- Form Side -->
  <div class="auth-form-side">
    <div class="auth-form-inner" style="max-width:460px;">
      <a href="/" style="display:inline-flex; align-items:center; gap:6px; color:var(--muted); font-size:0.875rem; margin-bottom:28px;" onmouseover="this.style.color='var(--teal)'" onmouseout="this.style.color='var(--muted)'">
        ← Back to NestDubai
      </a>

      <h2>Create Your Account</h2>
      <p>Free to register. No hidden fees. Start browsing instantly.</p>

      <% if (error) { %>
        <div class="alert alert-error" role="alert"><span aria-hidden="true">⚠️</span> <%= error %></div>
      <% } %>

      <form method="POST" action="/register" novalidate>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="name">Full Name <span class="required" aria-label="required">*</span></label>
            <input class="form-control" type="text" id="name" name="name"
              value="<%= formData.name || '' %>"
              placeholder="Your full name"
              autocomplete="name" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="phone">Phone Number</label>
            <input class="form-control" type="tel" id="phone" name="phone"
              value="<%= formData.phone || '' %>"
              placeholder="+971 50 000 0000"
              autocomplete="tel" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="email">Email Address <span class="required" aria-label="required">*</span></label>
          <input class="form-control" type="email" id="email" name="email"
            value="<%= formData.email || '' %>"
            placeholder="your@university.edu"
            autocomplete="email" required />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="nationality">Nationality</label>
            <input class="form-control" type="text" id="nationality" name="nationality"
              value="<%= formData.nationality || '' %>"
              placeholder="e.g. Indian, British…" />
          </div>
          <div class="form-group">
            <label class="form-label" for="university">University / College</label>
            <input class="form-control" type="text" id="university" name="university"
              value="<%= formData.university || '' %>"
              placeholder="e.g. Middlesex Dubai" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="student_id">Student ID <span style="font-weight:400;color:var(--muted);">(optional)</span></label>
          <input class="form-control" type="text" id="student_id" name="student_id"
            value="<%= formData.student_id || '' %>"
            placeholder="Your university student ID" />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="password">Password <span class="required" aria-label="required">*</span></label>
            <div class="password-toggle-wrap">
              <input class="form-control" type="password" id="password" name="password"
                placeholder="Min. 8 characters"
                autocomplete="new-password" required minlength="8" />
              <button type="button" class="password-toggle" aria-label="Toggle password visibility">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="confirm_password">Confirm Password <span class="required" aria-label="required">*</span></label>
            <div class="password-toggle-wrap">
              <input class="form-control" type="password" id="confirm_password" name="confirm_password"
                placeholder="Repeat password"
                autocomplete="new-password" required />
              <button type="button" class="password-toggle" aria-label="Toggle confirm password visibility">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>
        </div>

        <p class="text-xs text-muted" style="margin-bottom:16px;">
          By registering you agree to our Terms of Service. Your data is protected and encrypted. We never share your information.
        </p>

        <button type="submit" class="btn btn-primary btn-block">
          Create Free Account
        </button>
      </form>

      <div class="auth-switch">
        Already have an account? <a href="/login">Sign in →</a>
      </div>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
