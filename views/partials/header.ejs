<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="NestDubai — Affordable student accommodation in Dubai. Studios, private partitions, and bedspaces in Barsha Heights, TECOM, Discovery Gardens, and Al Barsha." />
  <title><%= title || 'NestDubai — Student Accommodation Dubai' %></title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- CSS -->
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="/css/pages.css" />

  <!-- Favicon -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏠</text></svg>" />
</head>
<body>

<!-- ═══ NAVBAR ═══════════════════════════════════════════════ -->
<header>
  <nav class="navbar" role="navigation" aria-label="Main navigation">
    <div class="navbar-inner">

      <a href="/" class="navbar-logo" aria-label="NestDubai Home">
        <div class="navbar-logo-icon" aria-hidden="true">🏠</div>
        Nest<span>Dubai</span>
      </a>

      <ul class="navbar-nav" role="menubar">
        <li role="none"><a href="/" class="nav-link" role="menuitem">Home</a></li>
        <li role="none"><a href="/properties" class="nav-link" role="menuitem">Properties</a></li>
        <li role="none"><a href="/about" class="nav-link" role="menuitem">About</a></li>
        <% if (user) { %>
          <% if (user.role === 'admin') { %>
            <li role="none"><a href="/admin" class="nav-link" role="menuitem">Admin</a></li>
          <% } %>
        <% } %>
      </ul>

      <div class="navbar-actions">
        <% if (user) { %>
          <div class="nav-user">
            <div class="nav-user-avatar" aria-hidden="true"><%= user.name.charAt(0).toUpperCase() %></div>
            <a href="/dashboard" class="nav-link"><%= user.name.split(' ')[0] %></a>
          </div>
          <a href="/logout" class="btn btn-outline btn-sm">Sign Out</a>
        <% } else { %>
          <a href="/login" class="btn btn-ghost btn-sm">Sign In</a>
          <a href="/register" class="btn btn-primary btn-sm">Register Free</a>
        <% } %>
      </div>

      <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobileMenu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Mobile navigation">
    <a href="/" class="mobile-nav-link">🏠 Home</a>
    <a href="/properties" class="mobile-nav-link">🏢 Properties</a>
    <a href="/about" class="mobile-nav-link">ℹ️ About</a>
    <% if (user) { %>
      <a href="/dashboard" class="mobile-nav-link">📊 My Dashboard</a>
      <% if (user.role === 'admin') { %>
        <a href="/admin" class="mobile-nav-link">⚙️ Admin Panel</a>
      <% } %>
      <a href="/logout" class="mobile-nav-link">🚪 Sign Out</a>
    <% } else { %>
      <a href="/login" class="mobile-nav-link">🔐 Sign In</a>
      <a href="/register" class="mobile-nav-link">✨ Register Free</a>
    <% } %>
  </div>
</header>

<main id="main-content">
