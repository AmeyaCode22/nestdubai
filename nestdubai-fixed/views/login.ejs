<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="/css/pages.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏠</text></svg>" />
</head>
<body>

<div class="auth-page" style="min-height:100vh;">
  <!-- Visual Side -->
  <aside class="auth-visual">
    <div class="auth-visual-img" aria-hidden="true"></div>
    <div class="auth-visual-content">
      <div class="auth-visual-logo">Nest<span>Dubai</span></div>
      <h2>Welcome Back to Your Dubai Home</h2>
      <p>Manage your booking, view your room details, and handle monthly payments — all in one place.</p>

      <div class="auth-feature">
        <div class="auth-feature-icon" aria-hidden="true">🏠</div>
        <div class="auth-feature-text">
          <h5>Your Room Dashboard</h5>
          <p>View your current booking, move-in details, and room information.</p>
        </div>
      </div>
      <div class="auth-feature">
        <div class="auth-feature-icon" aria-hidden="true">💳</div>
        <div class="auth-feature-text">
          <h5>Easy Monthly Payments</h5>
          <p>Pay your rent securely online each month. Track your payment history.</p>
        </div>
      </div>
      <div class="auth-feature">
        <div class="auth-feature-icon" aria-hidden="true">🔒</div>
        <div class="auth-feature-text">
          <h5>Fully Encrypted & Secure</h5>
          <p>Your data is protected with industry-standard encryption at all times.</p>
        </div>
      </div>
    </div>
  </aside>

  <!-- Form Side -->
  <div class="auth-form-side">
    <div class="auth-form-inner">
      <a href="/" style="display:inline-flex; align-items:center; gap:6px; color:var(--muted); font-size:0.875rem; margin-bottom:28px; transition:color var(--transition);" onmouseover="this.style.color='var(--teal)'" onmouseout="this.style.color='var(--muted)'">
        ← Back to NestDubai
      </a>

      <h2>Sign In</h2>
      <p>Access your student portal and manage your accommodation.</p>

      <% if (error) { %>
        <div class="alert alert-error" role="alert"><span aria-hidden="true">⚠️</span> <%= error %></div>
      <% } %>

      <form method="POST" action="/login" novalidate>
        <div class="form-group">
          <label class="form-label" for="email">Email Address <span class="required" aria-label="required">*</span></label>
          <input class="form-control" type="email" id="email" name="email"
            value="<%= formData.email || '' %>"
            placeholder="your@university.edu"
            autocomplete="email" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Password <span class="required" aria-label="required">*</span></label>
          <div class="password-toggle-wrap">
            <input class="form-control" type="password" id="password" name="password"
              placeholder="Enter your password"
              autocomplete="current-password" required />
            <button type="button" class="password-toggle" aria-label="Toggle password visibility">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-block" style="margin-top:8px;">
          Sign In to Portal
        </button>
      </form>

      <!-- Demo credentials hint -->
      <div style="margin-top:20px; padding:14px; background:var(--sand); border-radius:var(--radius-md); font-size:0.8rem; color:var(--slate);">
        <strong style="display:block; margin-bottom:6px; color:var(--charcoal);">🧪 Demo Accounts</strong>
        <div>Student: <code>demo@student.com</code> / <code>Demo1234!</code></div>
        <div style="margin-top:4px;">Admin: <code>admin@nestdubai.com</code> / <code>NestAdmin2025!</code></div>
      </div>

      <div class="auth-switch">
        Don't have an account? <a href="/register">Register free →</a>
      </div>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
