<%- include('partials/header') %>

<div style="background:var(--sand); min-height:100vh; padding-top:68px;">
  <div class="container">
    <div class="dashboard-layout">

      <!-- SIDEBAR -->
      <aside>
        <nav class="sidebar" aria-label="Dashboard navigation">
          <div class="sidebar-profile">
            <div class="sidebar-avatar" aria-hidden="true"><%= user.name.charAt(0).toUpperCase() %></div>
            <div class="sidebar-name"><%= user.name %></div>
            <div class="sidebar-role"><%= user.university || 'Student' %></div>
          </div>
          <div class="sidebar-nav">
            <a href="/dashboard" class="sidebar-link active">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              Dashboard
            </a>
            <a href="/book" class="sidebar-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
              Book a Room
            </a>
            <a href="/properties" class="sidebar-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Browse Properties
            </a>
            <div style="height:1px; background:var(--border); margin:8px 0;"></div>
            <a href="/logout" class="sidebar-link" style="color:var(--danger);">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Sign Out
            </a>
          </div>
        </nav>
      </aside>

      <!-- MAIN -->
      <main aria-label="Dashboard content">

        <!-- Welcome Banner -->
        <% if (welcome) { %>
          <div class="alert alert-success" data-autodismiss role="status">
            🎉 Welcome to NestDubai, <%= user.name.split(' ')[0] %>! Your account is ready. Browse properties and book your room.
          </div>
        <% } %>

        <div class="welcome-banner">
          <div>
            <h3>Welcome back, <%= user.name.split(' ')[0] %>! 👋</h3>
            <p>
              <% if (bookings.length > 0) { %>
                You have <%= bookings.filter(b => b.status === 'active').length %> active booking<%= bookings.filter(b=>b.status==='active').length!==1?'s':''%>.
              <% } else { %>
                You have no bookings yet. Find your perfect room below.
              <% } %>
            </p>
          </div>
          <a href="/book" class="btn btn-gold">+ Book a Room</a>
        </div>

        <!-- Stats -->
        <div class="dash-stats">
          <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(26,123,116,0.1);color:var(--teal);" aria-hidden="true">🏠</div>
            <div class="dash-stat-num"><%= bookings.filter(b=>b.status==='active').length %></div>
            <div class="dash-stat-label">Active Booking<%= bookings.filter(b=>b.status==='active').length!==1?'s':''%></div>
          </div>
          <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(201,146,42,0.1);color:var(--gold);" aria-hidden="true">💳</div>
            <div class="dash-stat-num"><%= bookings.filter(b=>b.payment_status==='paid').length %></div>
            <div class="dash-stat-label">Payments Made</div>
          </div>
          <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(28,36,51,0.06);color:var(--slate);" aria-hidden="true">📋</div>
            <div class="dash-stat-num"><%= bookings.length %></div>
            <div class="dash-stat-label">Total Booking<%= bookings.length!==1?'s':''%></div>
          </div>
        </div>

        <!-- Bookings -->
        <h3 style="font-size:1.2rem; margin-bottom:16px;">My Bookings</h3>

        <% if (bookings.length === 0) { %>
          <div style="background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); padding:56px; text-align:center;">
            <div style="font-size:3rem; margin-bottom:16px;" aria-hidden="true">🏠</div>
            <h4 style="margin-bottom:8px;">No bookings yet</h4>
            <p class="text-muted" style="margin-bottom:24px;">Browse our properties and find your perfect room in Dubai.</p>
            <a href="/properties" class="btn btn-primary">Browse Properties</a>
          </div>
        <% } else { %>
          <% bookings.forEach(booking => { %>
            <article class="booking-card">
              <div class="booking-card-header">
                <div style="display:flex; align-items:center; gap:10px;">
                  <div style="width:40px;height:40px;background:var(--teal);border-radius:var(--radius-sm);overflow:hidden;flex-shrink:0;">
                    <img src="<%= booking.property_image %>" alt="" style="width:100%;height:100%;object-fit:cover;" />
                  </div>
                  <div>
                    <div style="font-weight:700; font-size:0.9rem;"><%= booking.property_name %></div>
                    <div style="font-size:0.78rem; color:var(--muted);"><%= booking.area %></div>
                  </div>
                </div>
                <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                  <%
                    const statusColors = { active:'badge-success', pending:'badge-warning', cancelled:'badge-danger', completed:'badge-sand' };
                    const statusLabel = booking.status.charAt(0).toUpperCase() + booking.status.slice(1);
                  %>
                  <span class="badge <%= statusColors[booking.status] || 'badge-sand' %>"><%= statusLabel %></span>
                  <%
                    const payColors = { paid:'badge-success', unpaid:'badge-danger' };
                    const payLabel = booking.payment_status === 'paid' ? '✓ Paid' : '⚠ Unpaid';
                  %>
                  <span class="badge <%= payColors[booking.payment_status] || 'badge-warning' %>"><%= payLabel %></span>
                </div>
              </div>
              <div class="booking-card-body">
                <div class="booking-detail-grid">
                  <div class="booking-detail-item">
                    <span class="booking-detail-label">Room Type</span>
                    <span class="booking-detail-value"><%= booking.room_label %></span>
                  </div>
                  <div class="booking-detail-item">
                    <span class="booking-detail-label">Monthly Rent</span>
                    <span class="booking-detail-value" style="color:var(--teal);">AED <%= booking.price_monthly.toLocaleString() %></span>
                  </div>
                  <div class="booking-detail-item">
                    <span class="booking-detail-label">Move-in Date</span>
                    <span class="booking-detail-value"><%= new Date(booking.move_in_date).toLocaleDateString('en-AE', {day:'numeric',month:'long',year:'numeric'}) %></span>
                  </div>
                  <div class="booking-detail-item">
                    <span class="booking-detail-label">Duration</span>
                    <span class="booking-detail-value"><%= booking.duration_months %> months</span>
                  </div>
                  <div class="booking-detail-item">
                    <span class="booking-detail-label">Total Amount</span>
                    <span class="booking-detail-value">AED <%= (booking.total_amount || 0).toLocaleString() %></span>
                  </div>
                  <div class="booking-detail-item">
                    <span class="booking-detail-label">Booking Ref</span>
                    <span class="booking-detail-value" style="font-family:monospace;">#NEST-<%= String(booking.id).padStart(4,'0') %></span>
                  </div>
                </div>
                <% if (booking.payment_status === 'unpaid' && booking.status !== 'cancelled') { %>
                  <div style="margin-top:16px; padding-top:16px; border-top:1px solid var(--sand-dark); display:flex; justify-content:flex-end;">
                    <a href="/payment/<%= booking.id %>" class="btn btn-primary btn-sm">Complete Payment →</a>
                  </div>
                <% } %>
              </div>
            </article>
          <% }) %>
        <% } %>

        <!-- Profile Info -->
        <h3 style="font-size:1.2rem; margin-top:32px; margin-bottom:16px;">My Profile</h3>
        <div style="background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); padding:24px;">
          <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:16px;">
            <% const profileFields = [
              { label:'Full Name', value: user.name },
              { label:'Email Address', value: user.email },
              { label:'Phone', value: user.phone || 'Not provided' },
              { label:'Nationality', value: user.nationality || 'Not provided' },
              { label:'University', value: user.university || 'Not provided' },
              { label:'Student ID', value: user.student_id || 'Not provided' }
            ] %>
            <% profileFields.forEach(f => { %>
              <div>
                <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.06em; color:var(--muted); font-weight:600; margin-bottom:4px;"><%= f.label %></div>
                <div style="font-size:0.9rem; font-weight:500; color:var(--charcoal);"><%= f.value %></div>
              </div>
            <% }) %>
          </div>
          <div style="margin-top:20px; padding-top:16px; border-top:1px solid var(--sand-dark); display:flex; gap:8px;">
            <a href="/properties" class="btn btn-primary btn-sm">Browse More Rooms</a>
            <a href="mailto:hello@nestdubai.com" class="btn btn-outline btn-sm">Contact Support</a>
          </div>
        </div>

      </main>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
